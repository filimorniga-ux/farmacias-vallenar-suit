# AI_INTERNAL_ENDPOINT_TOKEN=replace-with-random-internal-token
# AI_DEEPSEEK_OCR_UPSTREAM_URL=https://api.deepseek.com/chat/completions
# NEXT_PUBLIC_STRIPE_KEY=pk_live_...
# NEXT_PUBLIC_ANALYTICS_ID=...
