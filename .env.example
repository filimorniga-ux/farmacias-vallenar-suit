# DATABASE (Tiger Cloud PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# APPLICATION
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.digitaloceanspaces.app
HEALTHCHECK_TOKEN=replace-with-random-token

# OPTIONAL: Additional Services
# AI_DEEPSEEK_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
